def project_name = 'batch-source'

// Jenkins 아이템별 환경변수로 주입 (GUI "This project is parameterised")
//   BATCH_JOB_NAME : 실행할 Spring Batch Job 이름
//
// 스케줄은 Jenkins GUI에서 설정:
//   Configure(구성) > Build Triggers > 'Build periodically(주기적으로 빌드)' 체크 후 cron 표현식 입력
//
// 아이템별 권장 설정:
//   batch-scraper : BATCH_JOB_NAME=emerging-tech.scraper.job, Schedule=H */6 * * *   (6시간마다)
//   batch-rss     : BATCH_JOB_NAME=emerging-tech.rss.job,     Schedule=H */4 * * *   (4시간마다)
//   batch-github  : BATCH_JOB_NAME=emerging-tech.github.job,  Schedule=H H(0-6) * * * (매일 새벽 1회)
def jobName = env.BATCH_JOB_NAME

pipeline {
    agent any

    parameters {
        choice(
            name: 'SPRING_PROFILE',
            choices: ['local', 'dev', 'beta', 'prod'],
            description: 'Spring 프로파일'
        )
    }

    environment {
        BUILD_DIR = "${JENKINS_HOME}/builds"
        PROJECT_NAME = "${project_name}"
        JAR_PATH = "${JENKINS_HOME}/builds/${project_name}.jar"
    }

    stages {
        stage('Validate Parameters') {
            steps {
                script {
                    if (!jobName) {
                        error """BATCH_JOB_NAME 환경변수가 설정되지 않았습니다.

[설정 방법]
1. Jenkins 대시보드에서 이 아이템 클릭
2. 좌측 메뉴 'Configure(구성)' 클릭
3. 'This project is parameterised(이 빌드는 매개변수가 있습니다)' 체크
4. 'Add Parameter(매개변수 추가)' > 'String Parameter(문자열 매개변수)' 선택
5. Name: BATCH_JOB_NAME / Default Value: 실행할 잡 이름 입력
   (예: emerging-tech.scraper.job, emerging-tech.rss.job, emerging-tech.github.job)
"""
                    }
                    echo "Parameters validated - Job: ${jobName}"
                }
            }
        }

        stage('Validate JAR') {
            steps {
                script {
                    if (!fileExists("${env.JAR_PATH}")) {
                        error "JAR file not found: ${env.JAR_PATH}. Run CI/CD Pipeline first."
                    }
                    echo "JAR validated: ${env.JAR_PATH}"
                }
            }
        }

        stage('Execute Batch Job') {
            steps {
                withCredentials([
                    string(credentialsId: 'github-token-batch-source', variable: 'GITHUB_TOKEN')
                ]) {
                    script {
                        echo "Executing: ${jobName} with profile ${params.SPRING_PROFILE}"

                        def exitCode = sh(
                            returnStatus: true,
                            script: """
                                java -Dspring.profiles.active=${params.SPRING_PROFILE} \
                                    -jar ${env.JAR_PATH} \
                                    --job.name=${jobName}
                            """
                        )

                        env.batchExitCode = "${exitCode}"

                        if (exitCode != 0) {
                            error "Batch Job failed with exit code: ${exitCode}"
                        }
                    }
                }
            }
        }

        stage('Health Check') {
            steps {
                echo "Batch Job completed successfully."
                echo "Job: ${jobName}"
                echo "Profile: ${params.SPRING_PROFILE}"
                echo "Exit Code: ${env.batchExitCode}"
            }
        }
    }

    post {
        failure {
            echo "=== BATCH JOB FAILURE ==="
            echo "Job: ${jobName}"
            echo "Profile: ${params.SPRING_PROFILE}"
            echo "Exit Code: ${env.batchExitCode}"
            echo "Check console output for detailed error logs."
        }
    }
}
